# P0-11 calibration UI — feature-flag gate + hydration cohort.
# Real OAuth + per-user identity wires in Phase 1; in Phase 0 the gate is
# substring-matched against `?as=<email>` against this allowlist.

# Comma-separated emails allowed to view /calibration.
CALIBRATION_ALLOWLIST=marie@anthos.org,erik@anthos.org,specialist1@anthos.org

# Comma-separated Salesforce Owner Ids whose caseloads form the calibration
# cohort. Each is hydrated server-side via the P0-08 bulk adapter.
CALIBRATION_OWNER_IDS=

# Public SF Lightning instance URL — drives the "Open in Salesforce ↗" link
# on the participant detail page. Non-secret. Leave empty to hide the link
# entirely. Sandbox example:
#   NEXT_PUBLIC_SF_INSTANCE_URL=https://anthoshome3--pursuit.sandbox.my.salesforce.com
NEXT_PUBLIC_SF_INSTANCE_URL=
