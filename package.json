{
  "name": "anthos-aftercare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Caseworker tooling for the Anthos|Home Aftercare program.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @anthos/web dev",
    "build": "pnpm --filter @anthos/web build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "e2e": "playwright test",
    "db:generate": "pnpm --filter @anthos/persistence db:generate",
    "db:check": "pnpm --filter @anthos/persistence db:check",
    "db:migrate": "pnpm --filter @anthos/persistence db:migrate",
    "db:migrate:down": "pnpm --filter @anthos/persistence db:migrate:down"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-security": "^3.0.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "pg": "^8.13.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
