<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <description>Tool-owned email Flow invoked by the Aftercare tool BFF (E-12) via the Actions REST API. Autolaunched so it is REST-invocable (GAP-8). DEMO posture: LOG-ONLY — it creates an Email Activity (Task) related to the Program Enrollment and returns its Id; it does NOT transmit mail (mirrors the SMS Dummy-Gateway posture). Production flips delivery on by adding an emailSimple action. Inputs match EmailFlowClient exactly: participant_id, subject, body, template_id. Output: activityId.</description>
    <environments>Default</environments>
    <interviewLabel>Anthos Tool Send Email {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Anthos Tool Send Email</label>
    <processType>AutoLaunchedFlow</processType>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <status>Active</status>
    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Email_Activity</targetReference>
        </connector>
    </start>
    <recordCreates>
        <name>Create_Email_Activity</name>
        <label>Create Email Activity</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignRecordIdToReference>activityId</assignRecordIdToReference>
        <inputAssignments>
            <field>Description</field>
            <value>
                <elementReference>body</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Subject</field>
            <value>
                <elementReference>subject</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>WhatId</field>
            <value>
                <elementReference>participant_id</elementReference>
            </value>
        </inputAssignments>
        <object>Task</object>
        <storeOutputAutomatically>false</storeOutputAutomatically>
    </recordCreates>
    <variables>
        <name>participant_id</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>subject</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>body</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>template_id</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>activityId</name>
        <dataType>String</dataType>
