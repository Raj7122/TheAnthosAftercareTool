# ─────────────────────────────────────────────────────────────
# Environment template.
# Copy this file to .env and fill in values for your local environment.
# Real values live in .env (gitignored) and in your deploy provider's env vars.
# All secrets below are server-side / BFF only — never expose them to the browser.
# ─────────────────────────────────────────────────────────────

# Postgres connection string (e.g. a pooled Supabase or Neon URL).
# Format: postgresql://user:password@host:port/database
DEMO_POSTGRES_URL=

# Salesforce `sf` CLI org alias used for local development and tooling.
# Run `sf org list` after `sf org login web --alias <alias>` to view aliases.
SF_MCP_ORG_ALIAS=

# ─────────────────────────────────────────────────────────────
# Microsoft SSO + MS Graph. One Entra ID app registration covers both
# specialist auth (Microsoft SSO, PKCE) and Outlook calendar access
# (MS Graph Calendars.ReadWrite). The client secret is BFF-only.
# ─────────────────────────────────────────────────────────────

# Entra ID directory (tenant) ID.
MS_TENANT_ID=

# Entra ID application (client) ID — single app, two scope sets.
MS_GRAPH_CLIENT_ID=

# Entra ID client secret — server-side / BFF only. Never expose to the browser.
MS_GRAPH_CLIENT_SECRET=

# OAuth callback URL registered in Entra → Authentication → Web → Redirect URIs.
# Register the production URL; add per-preview URIs on demand.
# Local dev: http://localhost:3000/api/auth/callback/microsoft.
MS_GRAPH_REDIRECT_URI=

# ─────────────────────────────────────────────────────────────
# Salesforce Connected App. Powers the BFF's non-interactive OAuth + PKCE path.
# Consumer Key + Secret come from deploying ConnectedApp metadata to the org;
# PKCE is required, refresh-token + token-exchange require the secret, scopes
# are Api + RefreshToken. The consumer secret is BFF-only.
# ─────────────────────────────────────────────────────────────

# Connected App Consumer Key (OAuth client_id). Found in Setup → App Manager,
# or via `sf project retrieve start --metadata ConnectedApp:<name>` (the
# consumerKey field is included in the retrieved XML).
SF_CONNECTED_APP_CONSUMER_KEY=

# Connected App Consumer Secret (OAuth client_secret). Server-side / BFF only.
# Not exposed via metadata retrieve or Tooling API SOQL — fetch once from
# Setup → Manage Consumer Details (requires identity verification).
SF_CONNECTED_APP_CONSUMER_SECRET=

# Salesforce login origin. Used by the BFF to construct OAuth + REST URLs
# (e.g., $SF_LOGIN_URL/services/oauth2/token).
SF_LOGIN_URL=

# Connected App refresh token. Server-side / BFF only. Minted ONCE via the
# interactive Authorization Code + PKCE bootstrap against the Connected App;
# the deployed BFF replays it via the grant_type=refresh_token flow to obtain
# access tokens non-interactively.
SF_CONNECTED_APP_REFRESH_TOKEN=

# ─────────────────────────────────────────────────────────────
# Bulk SOQL hydration adapter. Optional — the adapter has a built-in default
# `sf` CLI alias and is exercised primarily through unit tests. Set these only
# when running the opt-in live-sandbox integration test:
#   RUN_SF_SANDBOX_TESTS=1 SF_BULK_HYDRATION_OWNER_ID=… pnpm --filter @anthos/integrations test
# ─────────────────────────────────────────────────────────────

# Salesforce `sf` CLI alias for the bulk-hydration adapter. If unset, the
# adapter falls back to its built-in default alias.
SF_DEMO_ORG_ALIAS=

# Salesforce User Id whose caseload the integration test hydrates.
SF_BULK_HYDRATION_OWNER_ID=

# Tool-owned email Flow API name. The BFF invokes this autolaunched Salesforce
# Flow via the Actions REST API to send/log participant email. When unset,
# POST /participants/:id/emails returns 503 EMAIL_NOT_CONFIGURED. The Flow
# source lives in `salesforce/`. BFF-only.
EMAIL_FLOW_API_NAME=

# ─────────────────────────────────────────────────────────────
# Idempotency-keys TTL cleanup cron. The cron at /api/cron/idempotency-cleanup
# runs daily; the platform injects this value as a Bearer token on the cron
# request and the route rejects any request whose Authorization header does not
# match. Generate a random value per environment (e.g. `openssl rand -hex 32`).
# BFF-only — never exposed to the browser.
# ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Interactive Salesforce OAuth login (Authorization Code + PKCE).
# Powers GET /api/v1/auth/login — the per-specialist login entry point. Distinct
# from the server-to-server refresh-token path above; it reuses SF_LOGIN_URL +
# SF_CONNECTED_APP_CONSUMER_KEY. BFF-only.
# ─────────────────────────────────────────────────────────────

# Absolute URL of the OAuth callback, registered as a Callback URL on the
# Connected App. e.g. https://<host>/api/v1/auth/callback
SF_OAUTH_REDIRECT_URI=

# AEAD key for the encrypted anthos_oauth_state / anthos_oauth_pkce cookies
# (AES-256-GCM). Base64-encoded 32 random bytes. Generate: `openssl rand -base64 32`.
ANTHOS_OAUTH_COOKIE_SECRET=

# OAuth scope query-param tokens for the authorize URL. Optional — defaults to
# "api refresh_token". These are Salesforce OAuth scope tokens, NOT the
# Connected App object permissions (those are the permission set assigned to the
# Connected App, configured in Salesforce).
SF_OAUTH_SCOPE=

# Optional cookie-policy overrides for the OAuth pre-session cookies. Deployed
# environments use the defaults (Secure, SameSite=None — the Salesforce
# callback is a cross-site top-level navigation). Local dev over http can set
# ANTHOS_OAUTH_COOKIE_SECURE=false and ANTHOS_OAUTH_COOKIE_SAMESITE=Lax
# (browsers reject SameSite=None without Secure).
ANTHOS_OAUTH_COOKIE_SECURE=
ANTHOS_OAUTH_COOKIE_SAMESITE=

# ─────────────────────────────────────────────────────────────
# iframe parent-frame trust boundary (CSP + CSRF Origin defense).
# Both are env-driven so each environment carries its own allowlist with no
# code change. Both are OPTIONAL — the defaults below apply when unset.
# ─────────────────────────────────────────────────────────────

# CSP `frame-ancestors` source list — who may EMBED the SPA in an iframe.
# Space-separated. Defaults to
# "https://*.lightning.force.com https://*.salesforce.com"; tighten to an
# instance-specific host (e.g. https://<your-instance>.lightning.force.com)
# once the Salesforce admin confirms the final allowlist.
ANTHOS_CSP_FRAME_ANCESTORS=

# CSRF Origin allowlist — which origin a mutation request (POST/PATCH/DELETE)
# may come FROM, i.e. the BFF's own deployed origin(s). Comma- or
# space-separated. Defaults to http://localhost:3000 (local dev). Deployed
# environments MUST set this to the deployed URL; an unset value there fails
# closed (every mutation returns 403 CSRF_ORIGIN_MISMATCH).
ANTHOS_ALLOWED_ORIGINS=

# ─────────────────────────────────────────────────────────────
# HMAC signing key for opaque pagination cursors. Used by
# GET /api/v1/participants/:id/case-notes and any future cursor-paginated read
# endpoints. Base64-encoded 32 random bytes. Generate: `openssl rand -base64 32`.
# BFF-only — cursor tokens are signed, not encrypted; the secret never leaves
# the server. Deployed environments MUST set this; an unset value fails closed
# on any pagination request.
# ─────────────────────────────────────────────────────────────
ANTHOS_CURSOR_SIGNING_KEY=
