{
  "name": "@anthos/persistence",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, repositories, migrations.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:down": "tsx scripts/migrate-down.ts",
    "db:seed:offline-queue": "tsx scripts/seed-demo-offline-queue.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.30",
    "tsx": "^4.22.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthos/auth": "workspace:*",
    "@anthos/domain": "workspace:*",
    "dotenv": "^16",
    "drizzle-orm": "^0.36",
    "pg": "^8.13"
  }
}
